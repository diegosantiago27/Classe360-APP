## Frontend (Vite) — local
VITE_API_URL=http://localhost:8080

## Backend (Render + Supabase) — NÃO usar no .env local; configure no painel do Render
# SPRING_PROFILES_ACTIVE=prod
# SPRING_DATASOURCE_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=<senha do Supabase>
# JHIPSTER_SECURITY_AUTHENTICATION_JWT_BASE64_SECRET=<openssl rand -base64 64>
# JHIPSTER_CORS_ALLOWED_ORIGINS=https://<seu-app>.vercel.app
# JHIPSTER_MAIL_BASE_URL=https://<seu-backend>.onrender.com

## Frontend (Vercel) — configure no painel da Vercel
# VITE_API_URL=https://<seu-backend>.onrender.com


<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="00000000000023-1" author="classe360">
        <createTable tableName="user_storage">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_login" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="storage_key" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="value_text" type="clob"/>
        </createTable>
    </changeSet>

    <changeSet id="00000000000023-2" author="classe360">
        <addUniqueConstraint
            tableName="user_storage"
            columnNames="user_login, storage_key"
            constraintName="ux_user_storage_user_key"/>
    </changeSet>

    <changeSet id="00000000000023-3" author="classe360">
        <createIndex tableName="user_storage" indexName="idx_user_storage_user_login">
            <column name="user_login"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>

<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Adiciona campos de dados pessoais e endereço na tabela usuario -->
    <changeSet id="00000000000022-1" author="classe360">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="usuario"/>
        </preConditions>
        <addColumn tableName="usuario">
            <column name="data_nascimento" type="varchar(50)"/>
            <column name="telefone" type="varchar(50)"/>
            <column name="rua" type="varchar(255)"/>
            <column name="numero" type="varchar(20)"/>
            <column name="complemento" type="varchar(255)"/>
            <column name="bairro" type="varchar(255)"/>
            <column name="cidade" type="varchar(255)"/>
            <column name="cep" type="varchar(20)"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
